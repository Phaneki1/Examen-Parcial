@model IEnumerable<Examen_Parcial.Models.SolicitudCredito>

@{
    ViewData["Title"] = "Terminal de Analista";
}

<div class="fade-in-up">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0 text-danger fw-bolder"><i class="bi bi-shield-lock"></i> Terminal de Analista</h1>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i><strong>¡Éxito!</strong> @TempData["Success"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i><strong>Atención:</strong> @TempData["Error"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card shadow-lg border-0 glass-card delay-1 fade-in-up">
        <div class="card-header bg-transparent border-bottom border-secondary p-4" style="--bs-border-opacity: .2;">
            <h5 class="mb-0 text-white"><i class="bi bi-list-task text-primary me-2"></i> Evaluaciones Pendientes</h5>
        </div>
        <div class="card-body p-0">
            @if (!Model.Any())
            {
                <div class="p-5 text-center">
                    <i class="bi bi-check2-all text-success" style="font-size: 4rem;"></i>
                    <h4 class="mt-3 text-white">¡Mesa limpia!</h4>
                    <p class="mb-0 fs-5 text-muted">No hay solicitudes pendientes en este momento. Buen trabajo.</p>
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover mb-0 align-middle">
                        <thead>
                            <tr>
                                <th class="ps-4">ID</th>
                                <th>Cliente (Email)</th>
                                <th>Ingresos Mensuales</th>
                                <th>Monto Solicitado</th>
                                <th>Fecha</th>
                                <th class="text-center pe-4">Acción Inmediata</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model)
                            {
                                <tr>
                                    <td class="ps-4 fw-bold text-muted">#@item.Id</td>
                                    <td class="text-white">@item.Cliente!.Usuario!.UserName</td>
                                    <td>@item.Cliente.IngresosMensuales.ToString("C")</td>
                                    <td class="fw-bolder text-gradient fs-5">@item.MontoSolicitado.ToString("C")</td>
                                    <td class="text-muted">@item.FechaSolicitud.ToLocalTime().ToString("g")</td>
                                    <td class="text-center pe-4">
                                        <div class="btn-group shadow-sm" role="group">
                                            <!-- Formulario de Aprobación -->
                                            <form asp-action="Aprobar" asp-route-id="@item.Id" method="post" class="d-inline">
                                                <button type="submit" class="btn btn-sm btn-success rounded-start" onclick="return confirm('¿Estás seguro de APROBAR la solicitud #@item.Id del cliente @item.Cliente.Usuario.UserName?');">
                                                    <i class="bi bi-check-lg"></i> Aprobar
                                                </button>
                                            </form>
                                            
                                            <!-- Botón que abre el Modal de Rechazo -->
                                            <button type="button" class="btn btn-sm btn-danger rounded-end ms-1" data-bs-toggle="modal" data-bs-target="#rechazarModal-@item.Id">
                                                <i class="bi bi-x-lg"></i> Rechazar
                                            </button>
                                        </div>

                                        <!-- Modal Bootstrap de Rechazo -->
                                        <div class="modal fade text-start" id="rechazarModal-@item.Id" tabindex="-1" aria-labelledby="rechazarModalLabel-@item.Id" aria-hidden="true">
                                            <div class="modal-dialog modal-dialog-centered">
                                                <div class="modal-content border-danger" style="--bs-border-opacity: .5;">
                                                    <form asp-action="Rechazar" method="post">
                                                        <div class="modal-header bg-danger">
                                                            <h5 class="modal-title fw-bold" id="rechazarModalLabel-@item.Id"><i class="bi bi-shield-x me-2"></i> Denegar Solicitud #@item.Id</h5>
                                                            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Close"></button>
                                                        </div>
                                                        <div class="modal-body p-4">
                                                            <input type="hidden" name="SolicitudId" value="@item.Id" />
                                                            <div class="mb-3">
                                                                <label for="motivo-@item.Id" class="form-label text-muted small text-uppercase fw-bold">Motivo de Rechazo Obligatorio</label>
                                                                <textarea id="motivo-@item.Id" name="MotivoRechazo" class="form-control bg-dark text-white border-secondary" rows="4" required minlength="10" placeholder="Redacta el motivo (Mínimo 10 caracteres)..."></textarea>
                                                            </div>
                                                        </div>
                                                        <div class="modal-footer border-0 p-4 pt-0">
                                                            <button type="button" class="btn btn-secondary rounded-pill" data-bs-dismiss="modal">Cancelar</button>
                                                            <button type="submit" class="btn btn-danger fw-bold rounded-pill shadow-lg"><i class="bi bi-trash3 me-1"></i> Confirmar Rechazo</button>
                                                        </div>
                                                    </form>
                                                </div>
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
