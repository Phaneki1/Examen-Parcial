@model Examen_Parcial.Models.SolicitudCredito

@{
    ViewData["Title"] = "Detalle de Solicitud";
}

<h1 class="mb-4">Detalle de Solicitud</h1>

<div class="card shadow-sm col-md-8 mx-auto">
    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0">Solicitud #@Model.Id</h5>
        @if (Model.Estado == Examen_Parcial.Models.EstadoSolicitud.Aprobado)
        {
            <span class="badge bg-success fs-6">Aprobado</span>
        }
        else if (Model.Estado == Examen_Parcial.Models.EstadoSolicitud.Rechazado)
        {
            <span class="badge bg-danger fs-6">Rechazado</span>
        }
        else
        {
            <span class="badge bg-warning text-dark fs-6">Pendiente</span>
        }
    </div>
    <div class="card-body">
        <dl class="row mb-0">
            <dt class="col-sm-4">Monto Solicitado</dt>
            <dd class="col-sm-8 fs-5 fw-bold text-primary">@Model.MontoSolicitado.ToString("C")</dd>

            <dt class="col-sm-4">Fecha de Solicitud</dt>
            <dd class="col-sm-8">@Model.FechaSolicitud.ToLocalTime().ToString("f")</dd>

            @if (Model.Estado == Examen_Parcial.Models.EstadoSolicitud.Rechazado && !string.IsNullOrEmpty(Model.MotivoRechazo))
            {
                <dt class="col-sm-4 text-danger">Motivo de Rechazo</dt>
                <dd class="col-sm-8 text-danger">@Model.MotivoRechazo</dd>
            }
        </dl>
    </div>
    <div class="card-footer text-end">
        <a asp-action="Index" class="btn btn-secondary">Volver al listado</a>
    </div>
</div>
