@model Examen_Parcial.Models.SolicitudCredito

@{
    ViewData["Title"] = "Detalle de Solicitud";
}

<div class="fade-in-up mt-5">
    <div class="card shadow-lg col-md-6 mx-auto glass-card border-0">
        <div class="card-header bg-transparent border-bottom border-secondary p-4 d-flex justify-content-between align-items-center" style="--bs-border-opacity: .2;">
            <h4 class="mb-0 text-white fw-bold"><i class="bi bi-file-earmark-text text-primary me-2"></i> Solicitud <span class="text-muted">#@Model.Id</span></h4>
            @if (Model.Estado == Examen_Parcial.Models.EstadoSolicitud.Aprobado)
            {
                <span class="badge bg-success fs-6 px-3 py-2"><i class="bi bi-check-circle me-1"></i>Aprobado</span>
            }
            else if (Model.Estado == Examen_Parcial.Models.EstadoSolicitud.Rechazado)
            {
                <span class="badge bg-danger fs-6 px-3 py-2"><i class="bi bi-x-circle me-1"></i>Rechazado</span>
            }
            else
            {
                <span class="badge bg-warning fs-6 px-3 py-2"><i class="bi bi-clock me-1"></i>Pendiente</span>
            }
        </div>
        <div class="card-body p-5">
            <div class="mb-4">
                <span class="text-muted text-uppercase small fw-bold tracking-wide">Monto Solicitado</span>
                <div class="display-4 fw-bolder text-gradient mt-1">@Model.MontoSolicitado.ToString("C")</div>
            </div>

            <div class="mb-4">
                <span class="text-muted text-uppercase small fw-bold tracking-wide">Fecha de Solicitud</span>
                <div class="fs-5 text-white mt-1"><i class="bi bi-calendar3 text-secondary me-2"></i>@Model.FechaSolicitud.ToLocalTime().ToString("f")</div>
            </div>

            @if (Model.Estado == Examen_Parcial.Models.EstadoSolicitud.Rechazado && !string.IsNullOrEmpty(Model.MotivoRechazo))
            {
                <div class="mt-4 p-4 rounded-3 bg-danger" style="--bs-bg-opacity: .1; border: 1px solid rgba(239, 68, 68, 0.3);">
                    <span class="text-danger text-uppercase small fw-bold tracking-wide"><i class="bi bi-exclamation-triangle-fill me-1"></i> Motivo de Rechazo</span>
                    <div class="fs-6 text-white mt-2">@Model.MotivoRechazo</div>
                </div>
            }
        </div>
        <div class="card-footer bg-transparent border-top border-secondary p-4 text-end" style="--bs-border-opacity: .2;">
            <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4 hover-primary transition">
                <i class="bi bi-arrow-left me-1"></i> Volver al listado
            </a>
        </div>
    </div>
</div>
