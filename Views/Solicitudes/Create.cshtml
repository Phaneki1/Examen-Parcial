@model Examen_Parcial.Models.ViewModels.SolicitudCreateViewModel

@{
    ViewData["Title"] = "Nueva Solicitud de Crédito";
}

<div class="fade-in-up mx-auto" style="max-width: 600px; margin-top: 5vh;">
    <div class="text-center mb-5">
        <i class="bi bi-credit-card-2-front text-gradient" style="font-size: 3rem;"></i>
        <h2 class="fw-bold mt-3 text-white">Solicitar Crédito</h2>
        <p class="text-muted">Introduce el monto que necesitas. Evaluaremos tu perfil al instante.</p>
    </div>

    <div class="card shadow-lg border-0 glass-card">
        <div class="card-body p-5">
            <form asp-action="Create" method="post">
                
                @* Aquí aparecerán los errores de validación de servidor *@
                <div asp-validation-summary="ModelOnly" class="alert alert-danger fw-bold" role="alert"></div>

                <div class="mb-4">
                    <label asp-for="MontoSolicitado" class="form-label fs-6 fw-semibold text-muted text-uppercase tracking-wide">Monto a Solicitar</label>
                    <div class="input-group input-group-lg mt-2 shadow-sm rounded-3">
                        <span class="input-group-text bg-transparent border-end-0 text-primary fs-4 fw-bold">$</span>
                        <input asp-for="MontoSolicitado" class="form-control border-start-0 ps-0 fs-3 fw-bold bg-transparent text-white" type="number" step="0.01" placeholder="0.00" style="box-shadow: none;" />
                    </div>
                    <span asp-validation-for="MontoSolicitado" class="text-danger fw-bold mt-2 d-block"></span>
                    
                    <div class="form-text text-muted mt-3 p-3 rounded bg-dark border border-secondary" style="--bs-bg-opacity: .4;">
                        <i class="bi bi-info-circle text-info me-2"></i> 
                        El monto no debe superar <strong>10 veces</strong> tus ingresos mensuales. <br/>
                        <i class="bi bi-check2-circle text-success me-2 mt-2 d-inline-block"></i> Solo puedes tener <strong>una</strong> solicitud en estado Pendiente a la vez.
                    </div>
                </div>

                <div class="d-flex justify-content-between align-items-center mt-5 pt-3 border-top border-secondary" style="--bs-border-opacity: .2;">
                    <a asp-action="Index" class="btn btn-outline-secondary rounded-pill px-4">
                        <i class="bi bi-arrow-left me-1"></i> Volver
                    </a>
                    <button type="submit" class="btn btn-primary btn-lg px-5 rounded-pill fw-bold shadow-lg">
                        Confirmar <i class="bi bi-check2 ms-1"></i>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
