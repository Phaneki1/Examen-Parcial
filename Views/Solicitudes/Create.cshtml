@model Examen_Parcial.Models.ViewModels.SolicitudCreateViewModel

@{
    ViewData["Title"] = "Nueva Solicitud de Crédito";
}

<h1 class="mb-4">Nueva Solicitud de Crédito</h1>

<div class="row">
    <div class="col-md-6">
        <div class="card shadow-sm border-0">
            <div class="card-header bg-primary text-white">
                <h5 class="mb-0">Formulario de Registro</h5>
            </div>
            <div class="card-body bg-light">
                <form asp-action="Create" method="post">
                    
                    @* Aquí aparecerán los errores de validación de servidor *@
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger fw-bold" role="alert"></div>

                    <div class="mb-4">
                        <label asp-for="MontoSolicitado" class="form-label fs-5 fw-semibold"></label>
                        <div class="input-group input-group-lg">
                            <span class="input-group-text bg-white">$</span>
                            <input asp-for="MontoSolicitado" class="form-control" type="number" step="0.01" placeholder="Ej. 15000.00" />
                        </div>
                        <span asp-validation-for="MontoSolicitado" class="text-danger fw-bold"></span>
                        
                        <div class="form-text text-muted mt-2">
                            <i class="bi bi-info-circle"></i> 
                            El monto no debe superar 10 veces tus ingresos mensuales. <br/>
                            Solo puedes tener <strong>una</strong> solicitud en estado Pendiente a la vez.
                        </div>
                    </div>

                    <div class="d-flex justify-content-between mt-4">
                        <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                        <button type="submit" class="btn btn-primary px-4 fw-bold">Solicitar Crédito</button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
