@model Examen_Parcial.Models.ViewModels.SolicitudFilterViewModel
@{
    ViewData["Title"] = "Mis Solicitudes";
}

<div class="fade-in-up">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1 class="mb-0 text-white"><i class="bi bi-wallet2 text-gradient me-2"></i> Mis Solicitudes</h1>
        <a asp-action="Create" class="btn btn-success rounded-pill px-4 py-2 fw-bold shadow-lg"><i class="bi bi-plus-circle me-1"></i> Nueva Solicitud</a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i><strong>¡Éxito!</strong> @TempData["Success"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show shadow-sm" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i><strong>Atención:</strong> @TempData["Error"]
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    <div class="card mb-4 shadow-lg border-0 glass-card">
        <div class="card-body p-4">
            <h5 class="card-title text-muted mb-4"><i class="bi bi-funnel"></i> Filtros de Búsqueda</h5>
            <form asp-action="Index" method="get">
                <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                <div class="row g-3 align-items-end">
                    <div class="col-md-2">
                        <label asp-for="Estado" class="form-label text-muted small text-uppercase"></label>
                        <select asp-for="Estado" class="form-select" asp-items="Html.GetEnumSelectList<Examen_Parcial.Models.EstadoSolicitud>()">
                            <option value="">Todos</option>
                        </select>
                    </div>
                    <div class="col-md-2">
                        <label asp-for="MontoMinimo" class="form-label text-muted small text-uppercase"></label>
                        <input asp-for="MontoMinimo" class="form-control" type="number" step="0.01" placeholder="Mínimo" />
                    </div>
                    <div class="col-md-2">
                        <label asp-for="MontoMaximo" class="form-label text-muted small text-uppercase"></label>
                        <input asp-for="MontoMaximo" class="form-control" type="number" step="0.01" placeholder="Máximo" />
                    </div>
                    <div class="col-md-2">
                        <label asp-for="FechaInicio" class="form-label text-muted small text-uppercase"></label>
                        <input asp-for="FechaInicio" class="form-control" />
                    </div>
                    <div class="col-md-2">
                        <label asp-for="FechaFin" class="form-label text-muted small text-uppercase"></label>
                        <input asp-for="FechaFin" class="form-control" />
                    </div>
                    <div class="col-md-2">
                        <button type="submit" class="btn btn-primary rounded-pill w-100 fw-bold">Filtrar <i class="bi bi-search ms-1"></i></button>
                    </div>
                </div>
                
                <div class="row mt-2">
                    <div class="col-12">
                        <span asp-validation-for="MontoMinimo" class="text-danger d-block"></span>
                        <span asp-validation-for="MontoMaximo" class="text-danger d-block"></span>
                        <span asp-validation-for="FechaInicio" class="text-danger d-block"></span>
                        <span asp-validation-for="FechaFin" class="text-danger d-block"></span>
                    </div>
                </div>
            </form>
        </div>
    </div>

    @if (!Model.Solicitudes.Any())
    {
        <div class="card glass-card border-0 text-center p-5">
            <i class="bi bi-inbox text-muted" style="font-size: 4rem;"></i>
            <h4 class="mt-3 text-white">No hay solicitudes</h4>
            <p class="text-muted">No se encontraron solicitudes que coincidan con los criterios actuales.</p>
        </div>
    }
    else
    {
        <div class="card glass-card border-0 shadow-lg delay-1 fade-in-up">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle mb-0">
                        <thead>
                            <tr>
                                <th class="ps-4">Fecha Solicitud</th>
                                <th>Monto Solicitado</th>
                                <th>Estado</th>
                                <th class="text-end pe-4">Acciones</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var item in Model.Solicitudes)
                            {
                                <tr>
                                    <td class="ps-4 text-muted">@item.FechaSolicitud.ToLocalTime().ToString("g")</td>
                                    <td class="fw-bold text-white fs-5">@item.MontoSolicitado.ToString("C")</td>
                                    <td>
                                        @if (item.Estado == Examen_Parcial.Models.EstadoSolicitud.Aprobado)
                                        {
                                            <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Aprobado</span>
                                        }
                                        else if (item.Estado == Examen_Parcial.Models.EstadoSolicitud.Rechazado)
                                        {
                                            <span class="badge bg-danger"><i class="bi bi-x-circle me-1"></i>Rechazado</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-warning"><i class="bi bi-clock me-1"></i>Pendiente</span>
                                        }
                                    </td>
                                    <td class="text-end pe-4">
                                        <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info rounded-pill px-3">
                                            Ver Detalle <i class="bi bi-chevron-right ms-1"></i>
                                        </a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
