@model Examen_Parcial.Models.ViewModels.SolicitudFilterViewModel
@{
    ViewData["Title"] = "Mis Solicitudes";
}

<h1 class="mb-4">Mis Solicitudes</h1>

<div class="card mb-4 shadow-sm">
    <div class="card-body">
        <form asp-action="Index" method="get">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="row g-3 align-items-end">
                <div class="col-md-2">
                    <label asp-for="Estado" class="form-label"></label>
                    <select asp-for="Estado" class="form-select" asp-items="Html.GetEnumSelectList<Examen_Parcial.Models.EstadoSolicitud>()">
                        <option value="">Todos</option>
                    </select>
                </div>
                <div class="col-md-2">
                    <label asp-for="MontoMinimo" class="form-label"></label>
                    <input asp-for="MontoMinimo" class="form-control" type="number" step="0.01" />
                </div>
                <div class="col-md-2">
                    <label asp-for="MontoMaximo" class="form-label"></label>
                    <input asp-for="MontoMaximo" class="form-control" type="number" step="0.01" />
                </div>
                <div class="col-md-2">
                    <label asp-for="FechaInicio" class="form-label"></label>
                    <input asp-for="FechaInicio" class="form-control" />
                </div>
                <div class="col-md-2">
                    <label asp-for="FechaFin" class="form-label"></label>
                    <input asp-for="FechaFin" class="form-control" />
                </div>
                <div class="col-md-2">
                    <button type="submit" class="btn btn-primary w-100">Filtrar</button>
                </div>
            </div>
            
            <div class="row mt-2">
                <div class="col-12">
                    <span asp-validation-for="MontoMinimo" class="text-danger d-block"></span>
                    <span asp-validation-for="MontoMaximo" class="text-danger d-block"></span>
                    <span asp-validation-for="FechaInicio" class="text-danger d-block"></span>
                    <span asp-validation-for="FechaFin" class="text-danger d-block"></span>
                </div>
            </div>
        </form>
    </div>
</div>

@if (!Model.Solicitudes.Any())
{
    <div class="alert alert-info">No se encontraron solicitudes que coincidan con los criterios.</div>
}
else
{
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle">
            <thead class="table-dark">
                <tr>
                    <th>Fecha Solicitud</th>
                    <th>Monto Solicitado</th>
                    <th>Estado</th>
                    <th>Acciones</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model.Solicitudes)
                {
                    <tr>
                        <td>@item.FechaSolicitud.ToLocalTime().ToString("g")</td>
                        <td>@item.MontoSolicitado.ToString("C")</td>
                        <td>
                            @if (item.Estado == Examen_Parcial.Models.EstadoSolicitud.Aprobado)
                            {
                                <span class="badge bg-success">Aprobado</span>
                            }
                            else if (item.Estado == Examen_Parcial.Models.EstadoSolicitud.Rechazado)
                            {
                                <span class="badge bg-danger">Rechazado</span>
                            }
                            else
                            {
                                <span class="badge bg-warning text-dark">Pendiente</span>
                            }
                        </td>
                        <td>
                            <a asp-action="Details" asp-route-id="@item.Id" class="btn btn-sm btn-outline-info">Ver Detalle</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
