@{
    ViewData["Title"] = "Plataforma de Créditos";
}

<div class="container mt-5">
    <div class="row align-items-center">
        <div class="col-lg-6 text-center text-lg-start mb-5 mb-lg-0">
            <h1 class="display-4 fw-bold text-primary mb-3">Tu crédito, más rápido que nunca.</h1>
            <p class="lead text-muted mb-4">
                Solicita y gestiona tus créditos con respuesta inmediata. Un proceso transparente, seguro y diseñado para ti.
            </p>
            @if (User.Identity?.IsAuthenticated == true)
            {
                <a asp-controller="Solicitudes" asp-action="Index" class="btn btn-primary btn-lg px-4 shadow-sm">
                    Mis Solicitudes
                </a>
                @if (User.IsInRole("Analista"))
                {
                    <a asp-controller="Analista" asp-action="Index" class="btn btn-outline-secondary btn-lg px-4 ms-2">
                        Panel Analista
                    </a>
                }
            }
            else
            {
                <a href="/Identity/Account/Login" class="btn btn-primary btn-lg px-4 shadow-sm">
                    Iniciar Sesión
                </a>
                <a href="/Identity/Account/Register" class="btn btn-outline-primary btn-lg px-4 ms-2">
                    Registrarse
                </a>
            }
        </div>
        <div class="col-lg-6">
            <div class="card shadow border-0 rounded-4 bg-light">
                <div class="card-body p-5 text-center">
                    <h3 class="fw-bold text-success mb-3">✓ Evaluación Segura</h3>
                    <p class="text-muted">Nuestro sistema valida tu información en segundos garantizando el cumplimiento de todas las reglas de negocio.</p>
                </div>
            </div>
        </div>
    </div>
</div>
